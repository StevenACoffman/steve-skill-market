#!/usr/bin/env bash
# skill-diff — show what would change if a skill were updated from the marketplace
#
# Usage:
#   skill-diff <skill-name> [target-dir]
#
# target-dir defaults to the current working directory.
# Exit code 0 = no diff; 1 = differences exist; 2 = skill not installed in target.

set -euo pipefail

MARKET_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$MARKET_DIR/skills"

SKILL="${1:?error: skill name required}"
TARGET="${2:-.}"
TARGET="$(cd "$TARGET" && pwd)"

SRC="$SKILLS_DIR/$SKILL/SKILL.md"
DST="$TARGET/.agents/skills/$SKILL/SKILL.md"

if [[ ! -f "$SRC" ]]; then
  echo "error: '$SKILL' not found in marketplace" >&2
  exit 1
fi

if [[ ! -f "$DST" ]]; then
  echo "not installed: $SKILL"
  exit 2
fi

if diff -q "$SRC" "$DST" > /dev/null 2>&1; then
  echo "up to date: $SKILL"
  exit 0
else
  echo "diff for: $SKILL  (marketplace → installed)"
  diff --color=always -u "$SRC" "$DST" || true
  exit 1
fi
