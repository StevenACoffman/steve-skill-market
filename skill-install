#!/usr/bin/env bash
# skill-install — install skills from this marketplace into a target repo
#
# Usage:
#   skill-install <skill-name> [target-dir]            install one skill
#   skill-install --all [target-dir]                   install all skills
#   skill-install --from-manifest <file>               re-install from a manifest
#   skill-install --update <skill-name> [target-dir]   overwrite installed skill
#   skill-install --from-url <url> [skill|--all] [target-dir]  install from a GitHub URL
#   skill-install --list                               list available skills
#
# target-dir defaults to the current working directory.
# Skills are installed into <target-dir>/.agents/skills/<name>/SKILL.md
# A manifest entry is written to <target-dir>/.agents/skill-manifest.yml

set -euo pipefail

MARKET_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$MARKET_DIR/skills"

usage() {
  sed -n '2,13p' "$0" | sed 's/^# //'
  exit 1
}

# Resolve marketplace git SHA for manifest
market_sha() {
  git -C "$MARKET_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown"
}

# Return the canonical source reference for manifest entries.
# Prefers the git remote URL (normalised to HTTPS, .git suffix stripped)
# so the manifest is portable across machines. Falls back to the local path.
market_source() {
  local remote
  remote=$(git -C "$MARKET_DIR" remote get-url origin 2>/dev/null) || { echo "$MARKET_DIR"; return; }
  # Normalise SSH remote (git@github.com:org/repo.git) → HTTPS
  remote="${remote/git@github.com:/https://github.com/}"
  # Strip .git suffix
  remote="${remote%.git}"
  echo "$remote"
}

install_skill() {
  local skill="$1"
  local target="$2"
  local mode="${3:-install}"  # install | update

  local src="$SKILLS_DIR/$skill/SKILL.md"
  local dst_dir="$target/.agents/skills/$skill"
  local dst="$dst_dir/SKILL.md"

  if [[ ! -f "$src" ]]; then
    echo "error: skill '$skill' not found in marketplace" >&2
    exit 1
  fi

  if [[ "$mode" == "install" && -f "$dst" ]]; then
    echo "skip (already installed): $skill  (use --update to overwrite)"
    return
  fi

  mkdir -p "$dst_dir"
  cp "$src" "$dst"

  # Write/update manifest entry
  local manifest="$target/.agents/skill-manifest.yml"
  local sha source_ref date
  sha=$(market_sha)
  source_ref=$(market_source)
  date=$(date +%Y-%m-%d)

  mkdir -p "$target/.agents"
  touch "$manifest"

  # Remove existing entry for this skill, then append updated one
  local tmp
  tmp=$(mktemp)
  python3 - "$skill" "$manifest" "$tmp" << 'PYEOF'
import sys
skill, src_path, dst_path = sys.argv[1], sys.argv[2], sys.argv[3]
with open(src_path) as f:
    lines = f.readlines()
result = []
skip = 0
for line in lines:
    if skip > 0:
        skip -= 1
        continue
    if line.strip() == f"- skill: {skill}":
        skip = 3  # skip source + sha + installed_at lines
        continue
    result.append(line)
with open(dst_path, 'w') as f:
    f.writelines(result)
PYEOF

  cat >> "$tmp" << EOF
- skill: $skill
  source: $source_ref
  sha: $sha
  installed_at: $date
EOF
  mv "$tmp" "$manifest"

  echo "installed: $skill"
}

# Parse arguments
MODE=""
TARGET=""
SKILL_ARG=""
MANIFEST_FILE=""
FROM_URL=""

case "${1:-}" in
  --list)
    exec "$MARKET_DIR/skill-list"
    ;;
  --all)
    MODE="all"
    TARGET="${2:-.}"
    ;;
  --update)
    MODE="update"
    SKILL_ARG="${2:?error: --update requires a skill name}"
    TARGET="${3:-.}"
    ;;
  --from-manifest)
    MODE="from-manifest"
    MANIFEST_FILE="${2:?error: --from-manifest requires a manifest file path}"
    TARGET="$(dirname "$MANIFEST_FILE")/.."
    ;;
  --from-url)
    FROM_URL="${2:?error: --from-url requires a URL}"
    # Remaining args: optional skill name (or --all) and optional target dir
    shift 2
    case "${1:-}" in
      --all|"")
        MODE="all"
        TARGET="${2:-.}"
        ;;
      -*)
        echo "error: unexpected option after --from-url: '$1'" >&2; usage ;;
      *)
        MODE="one"
        SKILL_ARG="$1"
        TARGET="${2:-.}"
        ;;
    esac
    ;;
  --help|-h)
    usage
    ;;
  "")
    usage
    ;;
  -*)
    echo "error: unknown option '$1'" >&2
    usage
    ;;
  *)
    MODE="one"
    SKILL_ARG="$1"
    TARGET="${2:-.}"
    ;;
esac

# Resolve target to absolute path
TARGET="$(cd "$TARGET" && pwd)"

# If --from-url was given, clone the marketplace to a temp dir and redirect
# MARKET_DIR / SKILLS_DIR so the rest of the script works unchanged.
if [[ -n "$FROM_URL" ]]; then
  CLONE_DIR=$(mktemp -d)
  trap 'rm -rf "$CLONE_DIR"' EXIT
  echo "cloning $FROM_URL ..."
  git clone --depth 1 "$FROM_URL" "$CLONE_DIR/market" --quiet
  MARKET_DIR="$CLONE_DIR/market"
  SKILLS_DIR="$MARKET_DIR/skills"
fi

case "$MODE" in
  one)
    install_skill "$SKILL_ARG" "$TARGET" install
    ;;
  update)
    install_skill "$SKILL_ARG" "$TARGET" update
    ;;
  all)
    for skill_dir in "$SKILLS_DIR"/*/; do
      install_skill "$(basename "$skill_dir")" "$TARGET" install
    done
    ;;
  from-manifest)
    MANIFEST_FILE="$(cd "$(dirname "$MANIFEST_FILE")" && pwd)/$(basename "$MANIFEST_FILE")"
    while IFS= read -r line; do
      if [[ "$line" =~ ^-\ skill:\ (.+)$ ]]; then
        install_skill "${BASH_REMATCH[1]}" "$TARGET" update
      fi
    done < "$MANIFEST_FILE"
    ;;
esac
